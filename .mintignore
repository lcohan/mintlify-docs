# Mintlify automatically ignores these files and directories:
# .git, .github, .claude, .agents, .idea, node_modules,
# README.md, LICENSE.md, CHANGELOG.md, CONTRIBUTING.md

# Draft content
drafts/
*.draft.mdx

# Hidden pipeline content (kept on disk for easy re-enable; pipeline access is via the MCP server only)
api/pipelines/
pipelines/overview.mdx
pipelines/running.mdx
pipelines/ai-features.mdx
