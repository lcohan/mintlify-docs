  "keyFeatures": [
    "Repository-based organization for datasets and pipelines",
    "Visual pipeline builder with 40+ step types for data transformation",
    "15+ built-in data provider connectors (FRED, BLS, World Bank, Yahoo Finance, OECD, and more)",
    "Flexible data download with OData filtering, column selection, and multiple output formats (CSV, JSON, XLSX, TSV)",
    "AI-powered code generation and data summaries within pipelines",
    "API key and session-based authentication",
    "Chart and table SVG export",
    "Membership and subscription management",
    "Excel and Google Drive integrations",
    "Version history and dataset diff comparison"
  ],
  "publicApiSurface": [
    "GET /repositories — list repositories",
    "GET /repositories/{id} — get repository",
    "POST /repositories — create repository",
    "PUT /repositories/{id} — update repository",
    "DELETE /repositories/{id} — delete repository",
    "GET /datasets — list datasets",
    "GET /datasets/{id} — get dataset",
    "POST /datasets — create dataset",
    "DELETE /datasets/{id} — delete dataset",
    "GET /datasets/{id}/data — download dataset data (with $select, $filter, $top, $format, $last)",
    "PUT /datasets/{id}/data — upload data to dataset",
    "GET /datasets/{id}/columns — get dataset columns",
    "GET /pipelines — list pipelines",
    "GET /pipelines/{id} — get pipeline",
    "POST /pipelines — create pipeline",
    "PUT /pipelines/{id} — update pipeline",
    "DELETE /pipelines/{id} — delete pipeline",
    "POST /pipelines/{id}/runs — run pipeline",
    "GET /pipelines/{id}/runs/last — get last pipeline run",
    "GET /pipelines/{id}/steps — list pipeline steps",
    "POST /pipelines/{id}/steps — add pipeline step",
    "PUT /pipelines/{id}/steps/{step_id} — update pipeline step",
    "DELETE /pipelines/{id}/steps/{step_id} — delete pipeline step",
    "GET /providers — list data providers",
    "GET /providers/{slug} — get provider detail",
    "GET /providers/{slug}/search — search provider series",
    "GET /providers/{slug}/browse — browse provider hierarchy",
    "GET /providers/{slug}/series/{id} — preview series",
    "POST /providers/{slug}/series/{id}/data — fetch full series data",
    "GET /tickers/search/{query} — search financial tickers",
    "GET /tickers/{ticker}/data — get ticker historical data",
    "GET /fred/{symbol}/data — get FRED series data",
    "GET /series/{id}/data — get series data",
    "GET /memberships/plans — list membership plans",
    "GET /memberships — get current membership"
  ]
}
